<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Edge Smoke Suite" parallel="false">

    <test name="Edge Smoke">
        
        <!-- Browser parameter -->
        <parameter name="browser" value="edge"/>

        <!-- Run only smoke tests -->
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <!-- Test classes -->
        <classes>
            <class name="tests.LoginTest"/>
        </classes>

    </test>

</suite>